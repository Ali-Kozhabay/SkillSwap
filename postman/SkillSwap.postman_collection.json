                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Services loaded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const services = pm.response.json();",
                  "const serviceId = pm.collectionVariables.get(\"serviceId\");",
                  "const match = Array.isArray(services) ? services.find((service) => String(service.id) === serviceId) : null;",
                  "if (!match) {",
                  "  throw new Error(`Service ${serviceId} was not returned by /services/.`);",
