  "item": [
    {
      "name": "Provider Setup",
      "item": [
        {
          "name": "Register Provider",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{providerUsername}}\",\n  \"email\": \"{{providerEmail}}\",\n  \"password\": \"{{providerPassword}}\",\n  \"confirm_password\": \"{{providerPassword}}\",\n  \"first_name\": \"Postman\",\n  \"last_name\": \"Provider\",\n  \"location\": \"Almaty\",\n  \"bio\": \"Provider account generated for API verification.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register/",
            "description": "Creates a fresh provider account for this run and stores auth cookies."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now();",
                  "pm.collectionVariables.set(\"providerUsername\", `provider_${stamp}`);",
                  "pm.collectionVariables.set(\"providerEmail\", `provider_${stamp}@example.com`);",
                  "pm.collectionVariables.set(\"providerPassword\", \"demo12345\");",
                  "pm.collectionVariables.set(\"providerServiceTitle\", `Postman Service ${stamp}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Provider registered\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Provider Session",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/refresh/",
            "description": "Verifies refresh-cookie session renewal for the generated provider account."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Provider session refreshed\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Current User (Provider)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me/",
            "description": "Returns the currently authenticated provider profile."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Provider profile loaded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories/",
            "description": "Loads categories and stores the first category id for service creation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Categories loaded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const categories = pm.response.json();",
                  "if (!Array.isArray(categories) || !categories.length) {",
                  "  throw new Error(\"No categories found. Run seed_demo before using this collection.\");",
                  "}",
                  "pm.collectionVariables.set(\"categoryId\", String(categories[0].id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": {{categoryId}},\n  \"title\": \"{{providerServiceTitle}}\",\n  \"summary\": \"Structured one-session support created by the Postman verification flow.\",\n  \"description\": \"This service is created automatically to verify booking, messaging, and review endpoints end to end.\",\n  \"price\": \"15000.00\",\n  \"location\": \"Remote\",\n  \"is_active\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/services/",
            "description": "Creates a provider-owned service and stores its id for the rest of the flow."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Service created\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const payload = pm.response.json();",
                  "pm.collectionVariables.set(\"serviceId\", String(payload.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "My Services",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/services/mine/",
            "description": "Returns services owned by the generated provider account."
